generator client {
  provider        = "prisma-client"
  output          = "../generated"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum source_system {
  XERO
  MANUAL
}

enum employment_type {
  employee
  contractor
  director
  offshore
}

enum person_type {
  employee
  contractor
  director
  offshore_staff
}

enum payroll_region {
  AU
  NZ
  UK
}

enum xero_connection_status {
  pending
  pending_tenant_selection
  active
  stale
  disconnected
}

enum xero_oauth_session_status {
  pending
  completed
  expired
  cancelled
}

enum xero_person_match_status {
  pending
  matched
  ignored
}

enum xero_sync_entity_type {
  people
  leave_records
  leave_balances
}

enum sync_run_status {
  running
  succeeded
  partial_success
  failed
  cancelled
}

enum sync_run_type {
  people
  leave_records
  leave_balances
  approval_state_reconciliation
}

enum sync_trigger_type {
  scheduled
  manual
  webhook
}

enum sync_failed_record_type {
  people
  leave_records
  leave_balances
  approval_state_reconciliation
  leave
  annual_leave
  personal_leave
  holiday
  sick_leave
  long_service_leave
  unpaid_leave
  public_holiday
  wfh
  travel
  travelling
  training
  client_site
  another_office
  offsite_meeting
  contractor_unavailable
  limited_availability
  alternative_contact
  other
  leave_request
}

enum availability_record_type {
  leave
  annual_leave
  personal_leave
  holiday
  sick_leave
  long_service_leave
  unpaid_leave
  public_holiday
  wfh
  travel
  travelling
  training
  client_site
  another_office
  offsite_meeting
  contractor_unavailable
  limited_availability
  alternative_contact
  other
  leave_request
}

enum availability_source_type {
  xero
  xero_leave
  team_calendar_leave
  manual
}

enum availability_approval_status {
  draft
  submitted
  approved
  declined
  cancelled
  withdrawn
  xero_sync_failed
}

enum availability_failed_action {
  submit
  approve
  decline
  withdraw
}

enum availability_privacy_mode {
  named
  masked
  private
}

enum availability_contactability {
  contactable
  limited
  unavailable
  use_alternative_contact
}

enum availability_publish_status {
  eligible
  suppressed
  archived
}

enum leave_balance_unit {
  hours
  days
}

enum feed_scope_rule_type {
  org
  person
  team
  self
  manager_team
}

enum feed_status {
  active
  paused
  archived
}

enum feed_token_status {
  active
  revoked
  expired
}

enum notification_type {
  sync_failed
  sync_reconciliation_complete @map("sync.reconciliation_complete")
  feed_token_rotated
  privacy_conflict
  missing_alternative_contact
  leave_submitted
  leave_approved
  leave_declined
  leave_info_requested
  leave_xero_sync_failed
  leave_withdrawn
}

enum notification_email_status {
  queued
  sent
  failed
}

enum public_holiday_source {
  nager
  manual
}

enum public_holiday_type {
  public
  bank
  school
  authorities
  optional
  observance
  closure
  custom
}

enum public_holiday_assignment_scope_type {
  organisation
  location
  team
  person
  feed
}

enum public_holiday_day_classification {
  non_working
  working
}

enum plan_limit_type {
  active_people
  connections
  feeds
  organisations
  payroll_entities
  seats
}

// Billing cadence mirrored from Clerk. Clerk owns the price; this only records
// which cadence the Clerk subscription is on for display.
enum billing_interval {
  month
  year
}

// Hard-limit counter dimensions for the Clerk Billing slice. Mirrors the
// LimitType union in @repo/core. Distinct from the legacy free-text metric_key
// rows so the new generic enforcement path stays type-safe end to end.
enum usage_counter_type {
  payroll_entities
  seats
  feeds
}

model Organisation {
  id                    String    @id @default(uuid()) @db.Uuid
  clerk_org_id          String
  name                  String
  country_code          String
  region_code           String?
  is_active             Boolean   @default(true)
  timezone              String?
  locale                String?
  fiscal_year_start     Int?
  working_hours_per_day Decimal?  @db.Decimal(4, 2)
  reporting_unit        String?
  archived_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  teams                        Team[]
  locations                    Location[]
  people                       Person[]
  leave_balances               LeaveBalance[]
  alternative_contacts         AlternativeContact[]
  availability_records         AvailabilityRecord[]
  availability_publications    AvailabilityPublication[]
  feeds                        Feed[]
  feed_tokens                  FeedToken[]
  public_holiday_jurisdictions PublicHolidayJurisdiction[]
  public_holidays              PublicHoliday[]
  public_holiday_assignments   PublicHolidayAssignment[]
  xero_connection              XeroConnection?
  xero_tenants                 XeroTenant[]
  xero_oauth_sessions          XeroOAuthSession[]
  xero_person_matches          XeroPersonMatch[]
  xero_sync_cursors            XeroSyncCursor[]
  sync_runs                    SyncRun[]
  failed_records               FailedRecord[]
  audit_events                 AuditEvent[]
  notifications                Notification[]
  notification_preferences     NotificationPreference[]
  notification_email_queue     NotificationEmailQueue[]
  organisation_settings        OrganisationSettings?

  @@index([clerk_org_id])
  @@map("organisations")
}

model OrganisationSettings {
  id                                    String                    @id @default(uuid()) @db.Uuid
  clerk_org_id                          String
  organisation_id                       String                    @unique @db.Uuid
  show_pending_on_calendar              Boolean                   @default(true)
  show_declined_on_approvals            Boolean                   @default(true)
  notify_managers_on_status_change      Boolean                   @default(true)
  manager_visibility_scope              String                    @default("direct_reports_only")
  default_leave_request_advance_days    Int                       @default(0)
  require_decline_reason                Boolean                   @default(true)
  default_privacy_mode                  availability_privacy_mode @default(named)
  feeds_include_public_holidays_default Boolean                   @default(false)
  default_feed_privacy_mode             availability_privacy_mode @default(named)
  created_at                            DateTime                  @default(now())
  updated_at                            DateTime                  @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id], onDelete: Cascade)

  @@index([clerk_org_id])
  @@map("organisation_settings")
}

model Team {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  name            String
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  people       Person[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("teams")
}

model Location {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  name            String
  country_code    String?
  region_code     String?
  timezone        String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  people       Person[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("locations")
}

model Person {
  id                          String                      @id @default(uuid()) @db.Uuid
  clerk_org_id                String
  organisation_id             String                      @db.Uuid
  team_id                     String?                     @db.Uuid
  manager_person_id           String?                     @db.Uuid
  location_id                 String?                     @db.Uuid
  person_type                 person_type?
  source_system               source_system
  source_person_key           String?
  first_name                  String
  last_name                   String
  email                       String
  xero_employee_id            String?
  employment_type             employment_type
  is_active                   Boolean                     @default(true)
  display_name                String?
  clerk_user_id               String?
  job_title                   String?
  start_date                  DateTime?
  avatar_url                  String?
  status_note                 String?
  default_contactability      availability_contactability @default(contactable)
  default_privacy_mode        availability_privacy_mode   @default(named)
  include_in_feeds_by_default Boolean                     @default(true)
  archived_at                 DateTime?
  created_at                  DateTime                    @default(now())
  updated_at                  DateTime                    @updatedAt

  organisation           Organisation         @relation(fields: [organisation_id], references: [id])
  team                   Team?                @relation(fields: [team_id], references: [id])
  location               Location?            @relation(fields: [location_id], references: [id])
  manager                Person?              @relation("PersonManager", fields: [manager_person_id], references: [id])
  direct_reports         Person[]             @relation("PersonManager")
  leave_balances         LeaveBalance[]
  alternative_contacts   AlternativeContact[]
  availability_records   AvailabilityRecord[]
  approved_records       AvailabilityRecord[] @relation("ApprovedBy")
  xero_match_sources     XeroPersonMatch[]    @relation("XeroMatchSource")
  xero_match_candidates  XeroPersonMatch[]    @relation("XeroMatchCandidate")
  xero_match_resolutions XeroPersonMatch[]    @relation("XeroMatchResolution")
  notifications          Notification[]

  @@unique([organisation_id, source_system, source_person_key])
  @@unique([organisation_id, clerk_user_id])
  @@unique([organisation_id, xero_employee_id])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, team_id])
  @@index([organisation_id, manager_person_id])
  @@index([team_id])
  @@index([location_id])
  @@map("people")
}

model AlternativeContact {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  person_id       String   @db.Uuid
  name            String
  role            String?
  email           String?
  phone           String?
  notes           String?
  display_order   Int
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  person       Person       @relation(fields: [person_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id])
  @@index([person_id, display_order])
  @@map("alternative_contacts")
}

model XeroConnection {
  id                      String                 @id @default(uuid()) @db.Uuid
  clerk_org_id            String
  organisation_id         String                 @unique @db.Uuid
  status                  xero_connection_status @default(pending)
  access_token_encrypted  String                 @default("")
  access_token_iv         String?
  access_token_auth_tag   String?
  refresh_token_encrypted String                 @default("")
  refresh_token_iv        String?
  refresh_token_auth_tag  String?
  token_key_version       Int                    @default(1)
  token_encrypted_at      DateTime?
  expires_at              DateTime
  last_refreshed_at       DateTime?
  last_connected_at       DateTime?
  last_disconnected_at    DateTime?
  last_error_code         String?
  last_error_message      String?
  stale_since             DateTime?
  revoked_at              DateTime?
  disconnected_at         DateTime?
  disconnected_by_user_id String?
  created_at              DateTime               @default(now())
  updated_at              DateTime               @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  xero_tenant  XeroTenant?

  @@index([clerk_org_id])
  @@map("xero_connections")
}

model XeroTenant {
  id                                String         @id @default(uuid()) @db.Uuid
  clerk_org_id                      String
  organisation_id                   String         @db.Uuid
  xero_connection_id                String         @unique @db.Uuid
  xero_tenant_id                    String
  tenant_name                       String?
  payroll_region                    payroll_region
  sync_paused_at                    DateTime?
  last_people_sync_at               DateTime?
  last_leave_records_sync_at        DateTime?
  last_leave_balances_sync_at       DateTime?
  last_approval_state_reconciled_at DateTime?
  people_stale_since                DateTime?
  leave_records_stale_since         DateTime?
  leave_balances_stale_since        DateTime?
  approval_state_stale_since        DateTime?
  last_sync_error_code              String?
  last_sync_error_message           String?
  created_at                        DateTime       @default(now())
  updated_at                        DateTime       @updatedAt

  organisation    Organisation     @relation(fields: [organisation_id], references: [id])
  xero_connection XeroConnection   @relation(fields: [xero_connection_id], references: [id])
  sync_cursors    XeroSyncCursor[]
  leave_balances  LeaveBalance[]
  sync_runs       SyncRun[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("xero_tenants")
}

model XeroOAuthSession {
  id                      String                    @id @default(uuid()) @db.Uuid
  clerk_org_id            String
  organisation_id         String?                   @db.Uuid
  created_by_user_id      String?
  status                  xero_oauth_session_status @default(pending)
  return_to               String
  access_token_encrypted  String                    @default("")
  access_token_iv         String?
  access_token_auth_tag   String?
  refresh_token_encrypted String                    @default("")
  refresh_token_iv        String?
  refresh_token_auth_tag  String?
  token_key_version       Int                       @default(1)
  token_encrypted_at      DateTime?
  token_expires_at        DateTime
  available_tenants_json  Json
  selected_tenant_id      String?
  selected_tenant_name    String?
  selected_payroll_region payroll_region?
  expires_at              DateTime
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt

  organisation Organisation? @relation(fields: [organisation_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([status, expires_at])
  @@map("xero_oauth_sessions")
}

model XeroSyncCursor {
  id              String                @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String                @db.Uuid
  xero_tenant_id  String                @db.Uuid
  entity_type     xero_sync_entity_type
  cursor_value    String?
  created_at      DateTime              @default(now())
  updated_at      DateTime              @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  xero_tenant  XeroTenant   @relation(fields: [xero_tenant_id], references: [id])

  @@unique([xero_tenant_id, entity_type])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_tenant_id])
  @@map("xero_sync_cursors")
}

model AvailabilityRecord {
  id                       String                       @id @default(uuid()) @db.Uuid
  clerk_org_id             String
  organisation_id          String                       @db.Uuid
  person_id                String                       @db.Uuid
  record_type              availability_record_type
  source_type              availability_source_type
  source_remote_id         String?
  starts_at                DateTime
  ends_at                  DateTime
  approval_status          availability_approval_status
  failed_action            availability_failed_action?
  privacy_mode             availability_privacy_mode
  contactability           availability_contactability
  include_in_feed          Boolean                      @default(true)
  publish_status           availability_publish_status  @default(eligible)
  source_payload_json      Json?
  source_remote_hash       String?
  source_remote_version    String?
  source_last_modified_at  DateTime?
  derived_uid_key          String
  derived_sequence         Int                          @default(0)
  title                    String?
  all_day                  Boolean                      @default(true)
  notes_internal           String?
  working_location         String?
  preferred_contact_method String?
  created_by_user_id       String?
  updated_by_user_id       String?
  archived_at              DateTime?
  approval_note            String?
  approved_by_person_id    String?                      @db.Uuid
  approved_at              DateTime?
  xero_write_error         String?
  xero_write_error_raw     Json?
  submitted_at             DateTime?
  withdrawn_at             DateTime?
  created_at               DateTime                     @default(now())
  updated_at               DateTime                     @updatedAt

  organisation Organisation             @relation(fields: [organisation_id], references: [id])
  person       Person                   @relation(fields: [person_id], references: [id])
  approved_by  Person?                  @relation("ApprovedBy", fields: [approved_by_person_id], references: [id])
  publication  AvailabilityPublication?

  // Manual records have source_remote_id = NULL, which the composite unique above cannot
  // guard because PostgreSQL treats NULL as distinct. A partial unique index on
  // (organisation_id, person_id, record_type, starts_at, ends_at)
  // WHERE source_type = 'manual' AND source_remote_id IS NULL AND archived_at IS NULL
  // prevents duplicate manual entries (and the duplicate ICS events they would produce);
  // it is added via raw SQL in migration 20260606000000_manual_availability_partial_unique
  // because Prisma @@unique cannot express a WHERE clause. Keep both in sync; see that
  // migration for the index definition.
  @@unique([organisation_id, source_type, source_remote_id], map: "availability_records_source_identity_key")
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id, starts_at, ends_at])
  @@index([approved_by_person_id])
  @@index([source_type, source_remote_id])
  @@index([organisation_id, publish_status, include_in_feed])
  @@index([source_type, source_last_modified_at])
  @@map("availability_records")
}

model AvailabilityPublication {
  id                     String                    @id @default(uuid()) @db.Uuid
  clerk_org_id           String
  organisation_id        String                    @db.Uuid
  availability_record_id String                    @unique @db.Uuid
  published_uid          String
  published_summary      String
  published_description  String?
  published_all_day      Boolean                   @default(false)
  published_sequence     Int                       @default(0)
  published_at           DateTime
  privacy_mode           availability_privacy_mode
  created_at             DateTime                  @default(now())
  updated_at             DateTime                  @updatedAt

  organisation        Organisation       @relation(fields: [organisation_id], references: [id])
  availability_record AvailabilityRecord @relation(fields: [availability_record_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([published_uid])
  @@map("availability_publications")
}

model LeaveBalance {
  id                 String                    @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                    @db.Uuid
  person_id          String                    @db.Uuid
  // Nullable to support admin-managed manual balances when Xero is not connected.
  xero_tenant_id     String?                   @db.Uuid
  leave_type_xero_id String
  leave_type_name    String?
  record_type        availability_record_type?
  balance            Decimal                   @db.Decimal(12, 4)
  balance_unit       leave_balance_unit?
  as_at              DateTime?
  last_fetched_at    DateTime?
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  person       Person       @relation(fields: [person_id], references: [id])
  // Keep the existing Restrict behaviour so the nullable migration is just DROP NOT NULL,
  // rather than Prisma's optional-relation default of SetNull (which would force an FK rewrite).
  xero_tenant  XeroTenant?  @relation(fields: [xero_tenant_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // This composite unique guards Xero-sourced rows. Because PostgreSQL treats NULL as
  // distinct, it does NOT prevent duplicate manual balances once xero_tenant_id is null.
  // A partial unique index on (person_id, leave_type_xero_id) WHERE xero_tenant_id IS NULL
  // covers the manual case; it is added via raw SQL in migration
  // 20260605001000_leave_balances_nullable_tenant because Prisma @@unique cannot express a
  // WHERE clause. Keep both in sync; see that migration for the index definition.
  @@unique([person_id, xero_tenant_id, leave_type_xero_id])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([person_id])
  @@index([xero_tenant_id])
  @@map("leave_balances")
}

model XeroPersonMatch {
  id                     String                   @id @default(uuid()) @db.Uuid
  clerk_org_id           String
  organisation_id        String                   @db.Uuid
  xero_person_id         String                   @db.Uuid
  candidate_person_id    String?                  @db.Uuid
  detected_reason        String
  status                 xero_person_match_status @default(pending)
  resolution_note        String?
  resolved_person_id     String?                  @db.Uuid
  resolved_clerk_user_id String?
  resolved_by_user_id    String?
  resolved_at            DateTime?
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @updatedAt

  organisation     Organisation @relation(fields: [organisation_id], references: [id])
  xero_person      Person       @relation("XeroMatchSource", fields: [xero_person_id], references: [id])
  candidate_person Person?      @relation("XeroMatchCandidate", fields: [candidate_person_id], references: [id])
  resolved_person  Person?      @relation("XeroMatchResolution", fields: [resolved_person_id], references: [id])

  @@unique([xero_person_id, candidate_person_id], map: "xero_person_matches_source_candidate_key")
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([xero_person_id])
  @@index([candidate_person_id])
  @@index([status, created_at])
  @@map("xero_person_matches")
}

model PublicHolidayJurisdiction {
  id                 String                @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                @db.Uuid
  country_code       String
  region_code        String?
  source             public_holiday_source @default(nager)
  is_enabled         Boolean               @default(true)
  created_by_user_id String?
  updated_by_user_id String?
  archived_at        DateTime?
  created_at         DateTime              @default(now())
  updated_at         DateTime              @updatedAt

  organisation Organisation    @relation(fields: [organisation_id], references: [id])
  holidays     PublicHoliday[]

  @@unique([organisation_id, country_code, region_code])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("public_holiday_jurisdictions")
}

model PublicHoliday {
  id                     String                            @id @default(uuid()) @db.Uuid
  clerk_org_id           String
  organisation_id        String                            @db.Uuid
  jurisdiction_id        String?                           @db.Uuid
  source                 public_holiday_source
  source_remote_id       String?
  country_code           String
  region_code            String?
  holiday_date           DateTime
  name                   String
  local_name             String?
  holiday_type           public_holiday_type
  default_classification public_holiday_day_classification @default(non_working)
  notes_internal         String?
  source_payload_json    Json?
  created_by_user_id     String?
  updated_by_user_id     String?
  archived_at            DateTime?
  created_at             DateTime                          @default(now())
  updated_at             DateTime                          @updatedAt

  organisation Organisation               @relation(fields: [organisation_id], references: [id])
  jurisdiction PublicHolidayJurisdiction? @relation(fields: [jurisdiction_id], references: [id])
  assignments  PublicHolidayAssignment[]

  @@unique([organisation_id, source, source_remote_id])
  @@index([clerk_org_id])
  @@index([organisation_id, holiday_date])
  @@index([jurisdiction_id])
  @@map("public_holidays")
}

model PublicHolidayAssignment {
  id                 String                               @id @default(uuid()) @db.Uuid
  clerk_org_id       String
  organisation_id    String                               @db.Uuid
  public_holiday_id  String                               @db.Uuid
  scope_type         public_holiday_assignment_scope_type
  scope_value        String
  day_classification public_holiday_day_classification    @default(non_working)
  include_in_feeds   Boolean                              @default(true)
  notes_internal     String?
  created_by_user_id String?
  updated_by_user_id String?
  archived_at        DateTime?
  created_at         DateTime                             @default(now())
  updated_at         DateTime                             @updatedAt

  organisation   Organisation  @relation(fields: [organisation_id], references: [id])
  public_holiday PublicHoliday @relation(fields: [public_holiday_id], references: [id])

  @@unique([public_holiday_id, scope_type, scope_value])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([public_holiday_id])
  @@index([scope_type, scope_value])
  @@map("public_holiday_assignments")
}

model Feed {
  id                       String                    @id @default(uuid()) @db.Uuid
  clerk_org_id             String
  organisation_id          String                    @db.Uuid
  name                     String
  slug                     String
  description              String?
  status                   feed_status               @default(active)
  privacy_mode             availability_privacy_mode @default(named)
  includes_public_holidays Boolean                   @default(false)
  last_rendered_at         DateTime?
  last_etag                String?
  created_by_user_id       String?
  archived_at              DateTime?
  created_at               DateTime                  @default(now())
  updated_at               DateTime                  @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  scopes       FeedScope[]
  tokens       FeedToken[]

  @@unique([clerk_org_id, slug])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@map("feeds")
}

model FeedScope {
  id              String               @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String               @db.Uuid
  feed_id         String               @db.Uuid
  scope_type      feed_scope_rule_type
  scope_value     String?
  created_at      DateTime             @default(now())

  feed Feed @relation(fields: [feed_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([feed_id])
  @@index([scope_type, scope_value])
  @@map("feed_scopes")
}

model FeedToken {
  id                    String            @id @default(uuid()) @db.Uuid
  clerk_org_id          String
  organisation_id       String            @db.Uuid
  feed_id               String            @db.Uuid
  token_hash            String            @unique
  token_hint            String
  status                feed_token_status @default(active)
  expires_at            DateTime?
  revoked_at            DateTime?
  rotated_from_token_id String?           @db.Uuid
  last_used_at          DateTime?
  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  organisation       Organisation @relation(fields: [organisation_id], references: [id])
  feed               Feed         @relation(fields: [feed_id], references: [id])
  rotated_from_token FeedToken?   @relation("FeedTokenRotation", fields: [rotated_from_token_id], references: [id])
  rotated_tokens     FeedToken[]  @relation("FeedTokenRotation")

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([feed_id])
  @@index([rotated_from_token_id])
  @@map("feed_tokens")
}

model Notification {
  id                  String            @id @default(uuid()) @db.Uuid
  clerk_org_id        String
  organisation_id     String            @db.Uuid
  recipient_user_id   String
  recipient_person_id String?           @db.Uuid
  type                notification_type
  title               String
  body                String
  action_url          String?
  object_type         String?
  object_id           String?           @db.Uuid
  actor_user_id       String?
  payload             Json?
  read_at             DateTime?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  organisation     Organisation             @relation(fields: [organisation_id], references: [id])
  recipient_person Person?                  @relation(fields: [recipient_person_id], references: [id])
  email_queue      NotificationEmailQueue[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([recipient_person_id])
  @@index([recipient_user_id, read_at])
  @@index([recipient_user_id, created_at])
  @@index([organisation_id, recipient_user_id, created_at])
  @@map("notifications")
}

model NotificationPreference {
  id                String            @id @default(uuid()) @db.Uuid
  user_id           String
  clerk_org_id      String
  organisation_id   String            @db.Uuid
  notification_type notification_type
  in_app_enabled    Boolean           @default(true)
  email_enabled     Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])

  @@unique([user_id, organisation_id, notification_type])
  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([user_id])
  @@map("notification_preferences")
}

model NotificationEmailQueue {
  id                String                    @id @default(uuid()) @db.Uuid
  clerk_org_id      String
  organisation_id   String                    @db.Uuid
  notification_id   String?                   @db.Uuid
  recipient_user_id String
  notification_type notification_type
  email_template    String
  recipient_email   String
  title             String
  body              String
  action_url        String?
  unsubscribe_url   String
  merge_data        Json?
  status            notification_email_status @default(queued)
  attempts          Int                       @default(0)
  last_error        String?
  queued_at         DateTime                  @default(now())
  sent_at           DateTime?
  created_at        DateTime                  @default(now())
  updated_at        DateTime                  @updatedAt

  organisation Organisation  @relation(fields: [organisation_id], references: [id])
  notification Notification? @relation(fields: [notification_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([notification_id])
  @@index([recipient_user_id, status])
  @@index([status, queued_at])
  @@map("notification_email_queue")
}

model SyncRun {
  id                   String                 @id @default(uuid()) @db.Uuid
  clerk_org_id         String
  organisation_id      String                 @db.Uuid
  xero_tenant_id       String?                @db.Uuid
  status               sync_run_status        @default(running)
  run_type             sync_run_type
  trigger_type         sync_trigger_type      @default(scheduled)
  triggered_by_user_id String?
  entity_type          xero_sync_entity_type?
  records_fetched      Int                    @default(0)
  records_upserted     Int                    @default(0)
  records_skipped      Int                    @default(0)
  records_synced       Int                    @default(0)
  records_failed       Int                    @default(0)
  error_message        String?
  error_summary        String?
  cancel_requested_at  DateTime?
  started_at           DateTime
  completed_at         DateTime?
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt

  organisation   Organisation   @relation(fields: [organisation_id], references: [id])
  xero_tenant    XeroTenant?    @relation(fields: [xero_tenant_id], references: [id])
  failed_records FailedRecord[]

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, started_at])
  @@index([clerk_org_id, organisation_id, xero_tenant_id, run_type, status, started_at])
  @@map("sync_runs")
}

model FailedRecord {
  id               String                  @id @default(uuid()) @db.Uuid
  clerk_org_id     String
  organisation_id  String                  @db.Uuid
  sync_run_id      String                  @db.Uuid
  entity_type      xero_sync_entity_type
  record_type      sync_failed_record_type
  source_id        String
  source_remote_id String?
  error_code       String                  @default("unknown_error")
  error_message    String
  raw_payload      Json?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt

  organisation Organisation @relation(fields: [organisation_id], references: [id])
  sync_run     SyncRun      @relation(fields: [sync_run_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([sync_run_id])
  @@index([sync_run_id, created_at])
  @@map("failed_records")
}

model AuditEvent {
  id              String   @id @default(uuid()) @db.Uuid
  clerk_org_id    String
  organisation_id String   @db.Uuid
  actor_user_id   String?
  actor_display   String?
  action          String
  entity_type     String?
  entity_id       String?
  resource_type   String
  resource_id     String?
  metadata        Json?
  payload         Json?
  before_value    Json?
  after_value     Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime @default(now())

  organisation Organisation @relation(fields: [organisation_id], references: [id])

  @@index([clerk_org_id])
  @@index([organisation_id])
  @@index([organisation_id, created_at])
  @@index([organisation_id, entity_id])
  @@index([organisation_id, action, created_at, id], map: "audit_events_organisation_id_action_created_at_id_idx")
  @@index([organisation_id, entity_type, created_at, id], map: "audit_events_organisation_id_entity_type_created_at_id_idx")
  @@map("audit_events")
}

model Plan {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique // basic, premium, enterprise (kept == clerk_plan_key)
  name       String
  is_active  Boolean  @default(true)
  // Plan identity in the Clerk Dashboard. Plans, prices, and features are
  // configured in Clerk; this column mirrors the plan slug Clerk reports so the
  // catalogue and webhook can resolve a plan without depending on the legacy key.
  clerk_plan_key String?  @unique
  // Bespoke negotiated plans (for example custom enterprise) flag out of the
  // standard published catalogue. Seeded from PLAN_CATALOGUE.is_custom.
  is_custom      Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  limits                  PlanLimit[]
  clerk_org_subscriptions ClerkOrgSubscription[]

  @@map("plans")
}

model PlanLimit {
  id          String          @id @default(uuid()) @db.Uuid
  plan_id     String          @db.Uuid
  limit_type  plan_limit_type
  limit_value Int
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt

  plan Plan @relation(fields: [plan_id], references: [id])

  @@unique([plan_id, limit_type])
  @@index([plan_id])
  @@map("plan_limits")
}

model ClerkOrgSubscription {
  id                 String    @id @default(uuid()) @db.Uuid
  clerk_org_id       String    @unique
  plan_key           String
  // Clerk plan slug mirrored from the billing webhook. Written equal to
  // plan_key for plans seeded from PLAN_CATALOGUE; kept separate so a future
  // divergence between the legacy key and the Clerk slug does not break the FK.
  clerk_plan_key       String?
  status             String
  current_period_end DateTime?
  // Set when Clerk reports a scheduled downgrade or cancellation that takes
  // effect at the end of the current period.
  cancel_at_period_end Boolean          @default(false)
  // Mirrored billing cadence from Clerk. Null until the first webhook lands.
  billing_interval     billing_interval?
  seats_purchased    Int       @default(1)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  // Relation keyed on plan_key -> plans.key to avoid changing the existing column or
  // breaking billing-service.ts, which reads subscription.plan_key directly.
  plan Plan @relation(fields: [plan_key], references: [key])

  @@index([clerk_org_id])
  @@map("clerk_org_subscriptions")
}

model UsageCounter {
  id            String   @id @default(uuid()) @db.Uuid
  clerk_org_id  String
  metric_key    String
  // Typed hard-limit dimension for the Clerk Billing slice. Nullable so the
  // legacy metric_key rows coexist; the new generic enforcement and recount
  // path only ever read and write counter_type rows, one per (org, type).
  counter_type  usage_counter_type?
  current_value Int      @default(0)
  period_start  DateTime
  period_end    DateTime
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([clerk_org_id, metric_key, period_start, period_end])
  @@unique([clerk_org_id, counter_type])
  @@index([clerk_org_id])
  @@map("usage_counters")
}
