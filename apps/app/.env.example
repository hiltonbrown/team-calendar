# Team Calendar app (authenticated product UI) environment variables.
#
# Copy this file to .env.local and fill in the values you need. Optional
# variables with a format constraint (a URL, an email, or a required prefix)
# are commented out on purpose: an empty string fails Zod format validation
# even for an optional field, so leave them absent rather than set to "".

# --- Database (required) ---
DATABASE_URL=""

# --- Authentication (Clerk) ---
# CLERK_SECRET_KEY="sk_test_xxx"
# CLERK_WEBHOOK_SECRET="whsec_xxx"
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# --- Public URLs (shared across apps) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"
NEXT_PUBLIC_DOCS_URL="http://localhost:3004"
# Set automatically by Vercel in deployed environments.
VERCEL_PROJECT_PRODUCTION_URL="http://localhost:3000"

# --- Email (Resend) ---
# RESEND_FROM="noreply@example.com"
# RESEND_TOKEN="re_xxx"

# --- Xero OAuth + Payroll sync ---
# Required: AES-256-GCM key for encrypting Xero tokens at rest (32 bytes,
# base64-encoded). The value below is a development-only placeholder.
XERO_TOKEN_ENCRYPTION_KEY=""
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
# Optional override of the Xero API base URL (testing only).
# XERO_API_BASE_URL="https://api.xero.com"
# Pin the OAuth redirect URI to the URL registered on the Xero app. It must
# match a pre-registered callback exactly. Leave unset to derive it from
# NEXT_PUBLIC_API_URL. Xero connect is disabled on preview deployments.
# XERO_REDIRECT_URI="https://api.example.com/api/xero/oauth/callback"

# --- Feed cache (Vercel KV) ---
# Both must be set together to enable caching; a partial pair fails fast.
# KV_REST_API_URL="https://example.kv.vercel-storage.com"
# KV_REST_API_TOKEN="xxx"

# --- Notifications (Knock; optional) ---
KNOCK_SECRET_API_KEY=""
NEXT_PUBLIC_KNOCK_API_KEY=""
NEXT_PUBLIC_KNOCK_FEED_CHANNEL_ID=""

# --- Analytics (optional) ---
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXX"

# --- Observability (Sentry + BetterStack) ---
BETTERSTACK_API_KEY=""
# BETTERSTACK_URL="https://in.logs.betterstack.com"
SENTRY_ORG=""
SENTRY_PROJECT=""
# NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
